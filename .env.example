# Copy to .env and fill in what you need. Everything here is optional except the model API key.
# NEVER commit a real .env — only this example is tracked.

# ── Core ─────────────────────────────────────────────────────────────────────
# The port `bun run start` serves on. `bun run dev` ignores this: it pins the API to 3033 and puts
# Vite on 3032, so the URL you open is 3032 either way.
PORT=3032
# Where flat-file state lives (sessions, skills, workspace). Defaults to ./data
# DATA_DIR=./data
# Absolute origin the browser reaches, when behind a proxy/tunnel. Also the origin used to build
# session links in out-of-band notifications (push, scheduled-job failure alerts), which have no
# incoming request to derive it from — unset means those links are omitted rather than guessed.
# PUBLIC_ORIGIN=https://example.com

# ── Agent ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Which engines to enable. Default: claude-code
# AGENT_ENGINES=claude-code
# CURSOR_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# local (default) = self-hosted accounts, no external dependency.
# firebase        = verify Firebase ID tokens (requires the Firebase add-on + config below).
AUTH_PROVIDER=local
# Allow self-registration on a fresh instance (first user is always allowed).
# SHRAGA_ALLOW_SIGNUP=1

# Only for AUTH_PROVIDER=firebase. VITE_* is baked into the CLIENT bundle at build time —
# leave it unset for a local-auth build so nothing project-specific is compiled in.
# VITE_FIREBASE_CONFIG_PROD={"apiKey":"...","authDomain":"...","projectId":"..."}
# FIREBASE_CONFIG_PROD={"projectId":"..."}

# ── Optional integrations ────────────────────────────────────────────────────
# GITHUB_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_AGENT_CHANNEL=       # optional: a channel id that gets summon rules beyond @mentions
